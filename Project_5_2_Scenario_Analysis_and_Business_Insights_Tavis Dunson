    "scenario_results = pd.DataFrame({\n",
    "    'Scenario':['Baseline','Aging Population','Improved Cholesterol','Improved Fitness'],\n",
    "    'Predicted Risk':[0.50,0.65,0.42,0.37]\n",
    "})\n",
    "\n",
    "scenario_results\n"
